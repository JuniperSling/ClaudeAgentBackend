# ZhiPu API (GLM models, Anthropic-compatible endpoint)
ZHIPU_API_KEY=your-zhipu-api-key-here

# DeepSeek API (V4 models, Anthropic-compatible endpoint)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# OpenRouter API (Claude models via proxy)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Web search (Serper API / Google)
SERPER_API_KEY=your-serper-api-key-here

# Admin initial password (used on first startup to create admin user)
ADMIN_QQ_ID=your-qq-number
ADMIN_PASSWORD=changeme
